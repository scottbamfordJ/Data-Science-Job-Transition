    SELECT 
        customers.first_name,
        customers.last_name,
        count(orders.order_id) as Number_Of_Orders
    FROM customers
    LEFT JOIN orders on customers.customer_id = orders.customer_id
    GROUP BY customers.first_name, customers.last_name

